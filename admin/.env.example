# Vite Client Environment Configurations Example
# Copy this file to '.env' and fill in your Supabase project keys

# URL to your Supabase project backend
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Anon Public API key from Supabase dashboard (Settings -> API)
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# Port for local backend API endpoints redirection
VITE_API_URL=http://localhost:5000/api
