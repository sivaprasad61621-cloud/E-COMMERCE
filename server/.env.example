# Express Backend API Server Environment Configurations Example
# Copy this file to '.env' and fill in your keys

# Local port to host Express API
PORT=5000

# URL to your Supabase project backend
SUPABASE_URL=https://your-project-id.supabase.co

# Service Role Key from Supabase dashboard (Settings -> API)
# WARNING: Keep secret. Never expose this key in public client side.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Secret key for JWT session tokens signing
JWT_SECRET=your_production_secret_key_change_me_987654321

# Server mode (development or production)
NODE_ENV=development

# Email Notifications — Resend (https://resend.com)
# Sign up free and create an API key (3,000 emails/month free)
RESEND_API_KEY=re_your_resend_api_key_here

# Sender address shown in emails (must be a verified domain in Resend)
# Use onboarding@resend.dev for testing without domain verification
EMAIL_FROM=Velora <onboarding@resend.dev>
